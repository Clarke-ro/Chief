# Public Expo env only — never put private API keys or client secrets here.
# Copy to `.env` for local overrides (gitignored).

# Backend origin for authenticated API calls (no trailing slash)
# Production / shared staging:
# EXPO_PUBLIC_API_BASE_URL=https://api-production-5cea.up.railway.app
EXPO_PUBLIC_API_BASE_URL=https://api-production-5cea.up.railway.app

# Optional: development | preview | production
EXPO_PUBLIC_APP_ENV=development

# AI provider hint: mock | openai | anthropic | custom (no API keys in the client)
EXPO_PUBLIC_AI_PROVIDER=mock

# Supabase (Project Settings → API). Anon key only — never service_role in the app.
# EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Use RN fetch instead of ExpoFetchModule (safer when Expo Go native host is flaky)
# EXPO_PUBLIC_USE_RN_FETCH=true
