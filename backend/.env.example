# Local development — tunnel URLs are not used. Production uses Railway.

NODE_ENV=development
PORT=3000
APP_NAME=chief-api
API_PREFIX=v1
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Local Docker / Supabase
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chief?schema=public
REDIS_URL=redis://localhost:6379

# Better Auth — random 32+ char secret (openssl rand -base64 32). NOT a vendor API key.
BETTER_AUTH_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
# Local: http://localhost:3000
# Railway: leave unset and rely on RAILWAY_PUBLIC_DOMAIN, or set to https://your-service.up.railway.app
BETTER_AUTH_URL=http://localhost:3000

ENCRYPTION_KEY=change-me-to-a-32-char-encryption-key!!

# Optional locally; on Railway defaults to BETTER_AUTH_URL / public domain
OAUTH_REDIRECT_BASE_URL=http://localhost:3000
APP_OAUTH_SUCCESS_URL=chief://integrations/callback?status=success
APP_OAUTH_ERROR_URL=chief://integrations/callback?status=error

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional — leave blank to skip Microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

LOG_LEVEL=info
SWAGGER_ENABLED=true
