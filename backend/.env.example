# Local development defaults. Production values live on Railway / Supabase / Upstash.

NODE_ENV=development
PORT=3000
APP_NAME=chief-api
API_PREFIX=v1
# Include every web origin that may OAuth-return (Vercel production + previews, local web).
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,https://chief-nine-omega.vercel.app,chief://

# Supabase Postgres — use the direct URI for prisma migrate; pooler (Transaction) for the API if needed.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chief?schema=public

# Optional helpers (Nest uses DATABASE_URL via Prisma; these are for future Supabase client usage).
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=eyJ...

# Upstash Redis — paste the Redis URL from Upstash (prefer rediss:// TLS).
# BullMQ needs the TCP Redis URL, not the REST API URL.
REDIS_URL=redis://localhost:6379

BETTER_AUTH_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
# Dashboard API key from Better Auth Infrastructure (ba_...) — different from SECRET
BETTER_AUTH_API_KEY=
# Use the Railway public URL for OAuth + Better Auth (stable; no tunnels)
BETTER_AUTH_URL=https://api-production-5cea.up.railway.app
ENCRYPTION_KEY=change-me-to-a-32-char-encryption-key!!

OAUTH_REDIRECT_BASE_URL=https://api-production-5cea.up.railway.app
# Native defaults when the client omits returnTo. Web clients send HTTPS returnTo
# (must match an origin in CORS_ORIGINS) e.g. https://chief-nine-omega.vercel.app/integrations/callback
APP_OAUTH_SUCCESS_URL=chief://integrations/callback?status=success
APP_OAUTH_ERROR_URL=chief://integrations/callback?status=error

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Chief chat (server-side only — never expose to Expo / Vercel public env)
OPENAI_API_KEY=
AI_PROVIDER=openai
AI_MODEL=gpt-5.6
# Fallback when OpenAI fails or is unset
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

LOG_LEVEL=info
SWAGGER_ENABLED=true
