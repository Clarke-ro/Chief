{
  "expo": {
    "name": "Chief",
    "slug": "chief",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "chief",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#6D19B7",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "Chief",
      "shortName": "Chief",
      "description": "Your AI chief of staff for real work — priorities, daily brief, and next actions.",
      "themeColor": "#6D19B7",
      "backgroundColor": "#F7F7F8"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7F7F8",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "dark": {
            "backgroundColor": "#0C0C0E",
            "image": "./assets/splash-icon.png"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-asset",
        {
          "assets": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
